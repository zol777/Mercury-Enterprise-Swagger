                },
                "addressLine3": {
                    "type": "string"
                },
                "city": {
                    "type": "string"
                },
                "countryId": {
                    "type": "integer",
                    "format": "int64"
                },
                "dateOfBirth": {
                    "type": "string",
                    "format": "date"
                },
                "email": {
                    "type": "string"
                },
                "firstname": {
                    "type": "string"
                },
                "nationalities": {
                    "type": "array",
                    "items": {
                        "type": "integer",
                        "format": "int64"
                    }
                },
                "password": {
                    "type": "string"
                },
                "phoneCountryId": {
                    "type": "integer",
                    "format": "int64"
                },
                "phoneNumber": {
                    "type": "string"
                },
                "postCode": {
                    "type": "string"
                },
                "preferredCurrencies": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "registrationCountryId": {
                    "type": "number"
                },
                "sal": {
                    "type": "string"
                },
                "surname": {
                    "type": "string"
                },
                "usTaxIdNumber": {
                    "type": "string"
                }
