{
    "swagger": "2.0",
    "info": {
        "description": "Swagger api documentation for CurrencyFair enterprise API",
        "version": "1.0.0",
        "title": "CurrencyFair enterprise API"
    },
    "host": "api-test.staging.currencyfair.com",
    "basePath": "/enterprise",
    "tags": [
        {
            "name": "customer-v-1-controller",
            "description": "Customer V 1 Controller"
        }
    ],
    "schemes": [
        "https"
    ],
    "paths": {
        "/v1/customers": {
            "post": {
                "tags": [
                    "customer-v-1-controller"
                ],
                "summary": "Create customer",
                "description": "Create a new child customer under the current customer",
                "operationId": "createApiUserUsingPOST",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "*/*"
                ],
                "parameters": [
                    {
                        "in": "body",
                        "name": "apiUserCreateRequest",
                        "description": "apiUserCreateRequest",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/ApiUserCreateRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/ApiUserCreateResponse"
                        }
                    },
                    "201": {
                        "description": "Created"
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "403": {
                        "description": "Forbidden"
                    },
                    "404": {
                        "description": "Not Found"
                    }
                },
                "security": [
                    {
                        "Bearer Authentication": [
                            "global"
                        ]
                    }
                ]
            }
        },
        "/v1/customers/child-customers": {
            "get": {
                "tags": [
                    "customer-v-1-controller"
                ],
                "summary": "List customers",
                "description": "Query all child customers",
                "operationId": "queryAllChildCustomerUsingGET",
                "produces": [
                    "*/*"
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/ChildCustomerResponse"
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "403": {
                        "description": "Forbidden"
                    },
                    "404": {
                        "description": "Not Found"
                    }
                },
                "security": [
                    {
                        "Bearer Authentication": [
                            "global"
                        ]
                    }
                ]
            }
        },
        "/v1/customers/{customer_code}": {
            "get": {
                "tags": [
                    "customer-v-1-controller"
                ],
                "summary": "Query customer detail",
                "description": "Query customer detail by customer code",
                "operationId": "queryCustomerUsingGET",
                "produces": [
                    "*/*"
                ],
                "parameters": [
                    {
                        "name": "customer_code",
                        "in": "path",
                        "description": "customer_code",
                        "required": true,
                        "type": "string"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/ApiUserQueryResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "403": {
                        "description": "Forbidden"
                    },
                    "404": {
                        "description": "Not Found"
                    }
                },
                "security": [
                    {
                        "Bearer Authentication": [
                            "global"
                        ]
                    }
                ]
            }
        }
    },
    "securityDefinitions": {
        "Bearer Authentication": {
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    },
    "definitions": {
        "ApiUserCreateRequest": {
            "type": "object",
            "properties": {
                "is_accepted_terms_and_conditions": {
                    "type": "boolean"
                },
                "first_name": {
                    "type": "string"
                },
                "surname": {
                    "type": "string"
                },
                "sal": {
                    "type": "string"
                },
                "registration_country_id": {
                    "type": "number"
                },
                "phone_country_id": {
                    "type": "integer",
                    "format": "int64"
                },
                "phone_number": {
                    "type": "string"
                },
                "us_tax_id_number": {
                    "type": "string"
                },
                "date_of_birth": {
                    "type": "string",
                    "format": "date"
                },
                "nationalities": {
                    "type": "array",
                    "items": {
                        "type": "integer",
                        "format": "int64"
                    }
                },
                "preferred_currencies": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "post_code": {
                    "type": "string"
                },
                "address_line1": {
                    "type": "string"
                },
                "address_line2": {
                    "type": "string"
                },
                "address_line3": {
                    "type": "string"
                },
                "country_id": {
                    "type": "integer",
                    "format": "int64"
                },
                "city": {
                    "type": "string"
                }
            },
            "title": "ApiUserCreateRequest"
        },
        "ApiUserCreateResponse": {
            "type": "object",
            "properties": {
                "customer_id": {
                    "type": "string"
                }
            },
            "title": "ApiUserCreateResponse"
        },
        "ApiUserQueryResponse": {
            "type": "object",
            "properties": {
                "aml_flags": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "company": {
                    "type": "boolean"
                },
                "country_name": {
                    "type": "string"
                },
                "created": {
                    "type": "string",
                    "example": "yyyy-MM-dd HH:mm:ss"
                },
                "customer_code": {
                    "type": "string"
                },
                "display_user_name": {
                    "type": "string"
                },
                "firstname": {
                    "type": "string"
                },
                "pending_deposits_count": {
                    "type": "integer",
                    "format": "int32"
                },
                "sal": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                },
                "sub_user": {
                    "type": "boolean"
                },
                "surname": {
                    "type": "string"
                },
                "times_traded": {
                    "type": "integer",
                    "format": "int32"
                }
            },
            "title": "ApiUserQueryResponse"
        },
        "ChildCustomerResponse": {
            "type": "object",
            "properties": {
                "created": {
                    "type": "string",
                    "example": "yyyy-MM-dd HH:mm:ss"
                },
                "customer_code": {
                    "type": "string"
                },
                "firstname": {
                    "type": "string"
                },
                "surname": {
                    "type": "string"
                }
            },
            "title": "ChildCustomerResponse"
        }
    }
}
