        },
        "QueryCustomerListResponse": {
            "type": "object",
            "properties": {
                "created": {
                    "type": "string",
                    "format": "date-time"
                },
                "customerCode": {
                    "type": "string"
                },
                "firstname": {
                    "type": "string"
                },
                "surname": {
                    "type": "string"
                }
            },
            "title": "QueryCustomerListResponse"
        },
        "QueryCustomerResponse": {
            "type": "object",
            "properties": {
                "amlFlags": {
                    "type": "array",
                    "items": {
