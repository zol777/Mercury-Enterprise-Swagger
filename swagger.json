                    }
                },
                "company": {
                    "type": "boolean"
                },
                "countryName": {
                    "type": "string"
                },
                "created": {
                    "type": "string",
                    "format": "date-time"
                },
                "customerCode": {
                    "type": "string"
                },
                "displayUserName": {
                    "type": "string"
                },
                "firstname": {
                    "type": "string"
                },
                "pendingDepositsCount": {
                    "type": "integer",
                    "format": "int32"
                },
                "sal": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                },
                "subUser": {
                    "type": "boolean"
                },
                "surname": {
                    "type": "string"
                },
                "timesTraded": {
                    "type": "integer",
                    "format": "int32"
                }
            },
            "title": "QueryCustomerResponse"
        }
    }
}
